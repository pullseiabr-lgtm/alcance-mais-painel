NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Agente IA — Gestor de Tráfego
ANTHROPIC_API_KEY=sk-ant-...

# ── Meta Ads (Facebook + Instagram) ──────────────────────────────────────────
# Obtenha em: https://developers.facebook.com/tools/explorer/
# Permissões necessárias: ads_management, ads_read, business_management
META_ADS_ACCESS_TOKEN=EAAxxxxxx

# ── Google Ads ────────────────────────────────────────────────────────────────
# Console: https://developers.google.com/google-ads/api/docs/get-started/introduction
# Developer Token: https://ads.google.com/aw/apicenter (precisa de aprovação)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
# MCC (Manager Account) — opcional, apenas se gerenciar múltiplas contas
GOOGLE_ADS_MANAGER_ACCOUNT_ID=123-456-7890

# ── TikTok Ads ────────────────────────────────────────────────────────────────
# Console: https://business-api.tiktok.com/portal/docs
# Crie um app em: https://ads.tiktok.com/marketing_api/apps/
TIKTOK_ADS_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_ADS_APP_ID=your_app_id
TIKTOK_ADS_SECRET=your_app_secret

# ── Magnific AI — Criador de Arte ────────────────────────────────────────────
# Acesse: https://magnific.ai → Criar conta → Settings → API Keys
MAGNIFIC_API_KEY=your_magnific_api_key

# ── WhatsApp — Evolution API (self-hosted) ────────────────────────────────────
# Instale em: https://github.com/EvolutionAPI/evolution-api
# Ou use serviço gerenciado: https://evolution-api.com
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key
EVOLUTION_INSTANCE_NAME=alcance
